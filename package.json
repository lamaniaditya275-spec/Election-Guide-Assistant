{
  "name": "election-assistant",
  "version": "1.0.0",
  "description": "Interactive web application for understanding election processes, voter registration, voting methods, and ballot counting. Built with React, featuring smart personalization, comprehensive testing, and Google Services integration.",
  "keywords": [
    "election",
    "voting",
    "civic-education",
    "voter-registration",
    "accessible",
    "react",
    "google-api"
  ],
  "homepage": "https://election-assistant.example.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropic/election-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/anthropic/election-assistant/issues"
  },
  "author": "Election Assistant Team",
  "license": "MIT",
  "private": false,
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^3.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/react": "^18.0.0",
    "eslint": "^8.0.0",
    "eslint-config-react-app": "^7.0.1",
    "husky": "^9.1.7",
    "jest": "^27.5.1",
    "prettier": "^2.8.0"
  },
  "optionalDependencies": {
    "@sentry/react": "^7.0.0",
    "chart.js": "^3.9.0",
    "d3": "^7.8.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "CI=true npm test -- --coverage",
    "eject": "react-scripts eject",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css,md}\"",
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "lighthouse": "lighthouse https://localhost:3000 --view",
    "a11y:test": "axe src/",
    "coverage": "npm test -- --coverage --watchAll=false",
    "prepare": "husky install",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "deploy": "npm run build && vercel deploy --prod",
    "deploy:gh-pages": "npm run build && gh-pages -d build"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/**/*.test.{js,jsx}",
      "!src/index.js",
      "!src/reportWebVitals.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "rules": {
      "no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "no-console": [
        "warn",
        {
          "allow": [
            "warn",
            "error"
          ]
        }
      ],
      "react/jsx-no-target-blank": "warn",
      "react-hooks/rules-of-hooks": "error"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "bracketSpacing": true,
    "jsxBracketSameLine": false,
    "arrowParens": "always"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint && npm run format:check && npm test -- --bail"
    }
  },
  "proxy": "http://localhost:5000"
}
